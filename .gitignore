# =============================================================================
# test-case-sifting — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Jupyter
.ipynb_checkpoints/

# Type checkers / linters
.mypy_cache/
.ruff_cache/
.pytype/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# -----------------------------------------------------------------------------
# YOLO / PyTorch model weights (binary, large — download separately)
# See README.md > Installation for download instructions
# -----------------------------------------------------------------------------
*.pt
*.pth
*.onnx
*.engine
*.tflite
*.torchscript

# -----------------------------------------------------------------------------
# Data — never commit raw datasets or simulation outputs
# -----------------------------------------------------------------------------
data/raw/
data/uc1/
data/uc2/

# Intermediate pipeline data (generated by scripts)
*.pkl
generated_cycle*/
merged_cycle*/

# -----------------------------------------------------------------------------
# Training & fine-tuning artifacts (large, reproducible via scripts)
# -----------------------------------------------------------------------------
train_results/
fine-tuning/
*.zip

# -----------------------------------------------------------------------------
# Generated outputs (plots, CSVs produced at runtime)
# -----------------------------------------------------------------------------
outputs/plots/*.png
outputs/plots/*.pdf

# Root-level generated files
*.csv
cycle*_*.pkl
uc*_data*.pkl

# Temporary YOLO evaluation configs (created at runtime by PerformanceAnalyzer)
elite_data.yaml
naive_data.yaml
temp_bucket_data.yaml

# -----------------------------------------------------------------------------
# Development artefacts (work-in-progress copies — not part of the public API)
# -----------------------------------------------------------------------------
*copy*.py
* copy*.py
* copy *.py